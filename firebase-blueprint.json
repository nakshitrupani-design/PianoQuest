{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user progress and profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "xp": { "type": "number" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "xp"]
    },
    "Score": {
      "title": "Performance Score",
      "description": "Records individual song attempts",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "songId": { "type": "string" },
        "score": { "type": "number" },
        "accuracy": { "type": "number" },
        "combo": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "songId", "score"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and cumulative XP"
    },
    "/scores/{scoreId}": {
      "schema": "Score",
      "description": "Historical performance data for songs"
    }
  }
}
